{
  "name": "translator",
  "version": "1.0.1",
  "description": "",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "build": "next build",
    "changelog:generate": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -s -r 0",
    "dev": "next dev",
    "docs:toc": "node scripts/update-tocs.mjs && git add **/*.md",
    "format:check": "prettier . --check",
    "format": "prettier . --write",
    "lint:fix": "eslint . --fix",
    "lint": "eslint . --max-warnings=0",
    "plugin:wordpress:package": "node scripts/package-wordpress-plugin.mjs",
    "plugin:wordpress:php-lint": "find packages/wordpress-plugin -name '*.php' -print0 | xargs -0 -n1 php -l",
    "plugin:wordpress:release": "npm run verify && npm run plugin:wordpress:package",
    "release:major": "node ./scripts/release-bump.cjs major && npm run plugin:wordpress:release",
    "release:minor": "node ./scripts/release-bump.cjs minor && npm run plugin:wordpress:release",
    "release:patch": "node ./scripts/release-bump.cjs patch && npm run plugin:wordpress:release",
    "repo:public-check": "node scripts/public-repo-check.mjs",
    "start": "next start",
    "test:e2e": "npm run build && playwright test",
    "test:unit": "jest --runInBand",
    "test:wordpress": "php packages/wordpress-plugin/tests/run.php",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "version:next": "npm run release:patch",
    "vercel:deploy:prod": "npx vercel@latest --prod",
    "vercel:deploy": "npx vercel@latest",
    "vercel:link": "npx vercel@latest link",
    "vercel:pull": "npx vercel@latest env pull .env.local",
    "verify": "npm run lint && npm run typecheck && npm run format:check && npm run test:unit && npm run test:wordpress && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thomaskungforlag/translator.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@mui/material-nextjs": "^9.0.1",
    "next": "^16.2.6",
    "openai": "^6.37.0",
    "pdf-parse": "^1.1.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.2",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "conventional-changelog-cli": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  }
}
